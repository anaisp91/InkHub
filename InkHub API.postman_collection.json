            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"artist12@test.com\",\n  \"password\": \"123456\",\n  \"artistData\": {\n    \"name\": \"artist 12\",\n    \"lastName\": \"art 12\",\n    \"persId\": \"65465554\",\n    \"phoneNum\": \"369855741\",\n    \"SanNum\": \"S11155011\"\n  }\n}",
              "options": {
