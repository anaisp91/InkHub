          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \n    \"email\": \"example@email.com\",\n    \"password\": \"passwordexample\",\n    \"studioData\": {\n        \"name\": \"Example tattoo Studio\" ,\n        \"address\": \"example\",\n        \"phoneNum\": \"111111111\"\n    }\n    \n    \n    \n}",
