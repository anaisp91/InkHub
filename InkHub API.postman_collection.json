{
  "info": {
    "_postman_id": "e689e38e-260d-43cd-bd19-666b3093c993",
    "name": "InkHub API",
    "description": "InkHub es una API diseñada para la gestión integral de estudios de tatuaje. Permite registrar estudios, administrar artistas asociados, gestionar clientes y digitalizar consentimientos, optimizando el almacenamiento y la trazabilidad de la información.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "51655987",
    "_collection_link": "https://go.postman.co/collection/51655987-e689e38e-260d-43cd-bd19-666b3093c993?source=collection_link"
  },
